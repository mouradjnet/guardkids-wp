# URL do WordPress de desenvolvimento (LocalWP). Vite faz proxy de /wp-json/* pra esse host.
VITE_WP_URL=http://guardkids.local

# Application Password do WordPress pra autenticar a REST em desenvolvimento.
# Crie em wp-admin → Usuários → seu perfil → Application Passwords.
# Copie o valor gerado (com ou sem espaços, tanto faz) e cole abaixo.
VITE_WP_USER=admin
VITE_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
