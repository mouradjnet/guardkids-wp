# Upstream do nginx do site no LocalWP (porta visível em LocalWP -> Site -> Advanced).
# Default 127.0.0.1:10034 bate com o site guardkids-wp; ajustar se LocalWP atribuiu outra.
# O Vite proxy aponta DIRETO pra esse alvo, pulando o router LocalWP em :80
# (que trava no Windows quando chamado via http-proxy do Vite).
VITE_WP_PROXY_TARGET=http://127.0.0.1:10034

# Application Password do WordPress pra autenticar a REST em desenvolvimento.
# Crie em wp-admin -> Usuários -> seu perfil -> Application Passwords.
# Copie o valor gerado (com ou sem espaços, tanto faz) e cole abaixo.
VITE_WP_USER=admin
VITE_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
