{
    "name": "guardkids/guardkids-wp",
    "description": "GuardKids WP — plugin WordPress premium de controle parental web + PWA.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "GuardKids\\": "includes/",
            "GuardKids\\Api\\": "api/",
            "GuardKids\\Database\\": "database/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
